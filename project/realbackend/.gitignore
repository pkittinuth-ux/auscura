# Dependencies
node_modules/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Audio recordings & binary data
*.pcm
*.wav
*.mp3
*.ogg
recordings/
audio_output/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Test coverage
coverage/
.nyc_output/

# Build output
dist/
build/

# Editor & OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Misc
*.local
